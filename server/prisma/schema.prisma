generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  tickets    Ticket[]
  categories Category[]
  labels     Label[]
  canvas     CanvasIntegration?
}

model Ticket {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  status             String    @default("BACKLOG")
  priority           String    @default("MEDIUM")
  category           Category  @relation(fields: [categoryId], references: [id])
  categoryId         String
  labels             Label[]
  dueDate            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  order              Int       @default(0)
  canvasAssignmentId String?
  canvasCourseId     String?
  user               User      @relation(fields: [userId], references: [id])
  userId             String

  @@index([status])
  @@index([categoryId])
  @@index([priority])
  @@index([userId])
  @@index([canvasAssignmentId])
}

model Category {
  id      String   @id @default(uuid())
  name    String
  color   String   @default("#000000")
  icon    String   @default("folder")
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  tickets Ticket[]

  @@unique([name, userId])
}

model Label {
  id      String   @id @default(uuid())
  name    String
  color   String   @default("#000000")
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  tickets Ticket[]

  @@unique([name, userId])
}

model CanvasIntegration {
  id        String   @id @default(uuid())
  baseUrl   String
  apiToken  String
  userId    String   @unique
  userName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}
